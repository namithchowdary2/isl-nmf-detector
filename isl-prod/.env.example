# Copy to .env and fill in your values
# Generate secrets with: python3 -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY=change-me-generate-with-python-secrets
JWT_SECRET=change-me-generate-with-python-secrets

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite:///isl_nmf.db
# DATABASE_URL=postgresql://user:password@db:5432/isl_nmf

# Redis
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# Server
PORT=5000
WORKERS=4
FLASK_ENV=development
DEBUG=false

# Rate limits
RATE_LIMIT_DEFAULT=300/hour
RATE_LIMIT_DETECT=120/minute
RATE_LIMIT_AUTH=10/minute

# Frontend API URL (for Docker)
REACT_APP_API_URL=http://localhost:5000
